[debug] [2026-03-23T17:07:29.109Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/agendamento-ai-9fbfb/rulesets {"name":"projects/agendamento-ai-9fbfb/rulesets/f8b93df4-5220-4944-82d1-d20284768e12","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isNonEmptyString(value, maxLength) {\n      return value is string && value.size() > 0 && value.size() <= maxLength;\n    }\n\n    function isIsoDate(value) {\n      return value is string && value.matches('^\\\\d{4}-\\\\d{2}-\\\\d{2}$');\n    }\n\n    function isHourMinute(value) {\n      return value is string && value.matches('^([01]\\\\d|2[0-3]):[0-5]\\\\d$');\n    }\n\n    function isAllowedStatus(value) {\n      return value == 'pending' || value == 'confirmed' || value == 'cancelled';\n    }\n\n    function tenantIsActive(tenantId) {\n      return exists(/databases/$(database)/documents/tenants/$(tenantId))\n        && get(/databases/$(database)/documents/tenants/$(tenantId)).data.active == true;\n    }\n\n    function serviceBelongsToTenant(serviceId, tenantId) {\n      return exists(/databases/$(database)/documents/services/$(serviceId))\n        && get(/databases/$(database)/documents/services/$(serviceId)).data.tenantId == tenantId\n        && get(/databases/$(database)/documents/services/$(serviceId)).data.active == true;\n    }\n\n    function hasOnlyKeys(data, allowedKeys) {\n      return data.keys().hasAll(allowedKeys) && data.keys().hasOnly(allowedKeys);\n    }\n\n    function isValidPublicAppointment(data) {\n      return hasOnlyKeys(data, ['tenantId', 'date', 'time', 'status', 'createdAt', 'updatedAt'])\n        && isNonEmptyString(data.tenantId, 120)\n        && tenantIsActive(data.tenantId)\n        && isIsoDate(data.date)\n        && isHourMinute(data.time)\n        && data.status == 'pending'\n        && data.createdAt is timestamp\n        && data.updatedAt is timestamp;\n    }\n\n    function isValidAppointment(data) {\n      return hasOnlyKeys(\n          data,\n          [\n            'tenantId',\n            'serviceId',\n            'serviceNameSnapshot',\n            'date',\n            'time',\n            'customerName',\n            'customerPhone',\n            'notes',\n            'status',\n            'createdAt',\n            'updatedAt'\n          ]\n        )\n        && isNonEmptyString(data.tenantId, 120)\n        && tenantIsActive(data.tenantId)\n        && isNonEmptyString(data.serviceId, 120)\n        && serviceBelongsToTenant(data.serviceId, data.tenantId)\n        && isNonEmptyString(data.serviceNameSnapshot, 120)\n        && isIsoDate(data.date)\n        && isHourMinute(data.time)\n        && isNonEmptyString(data.customerName, 120)\n        && isNonEmptyString(data.customerPhone, 20)\n        && data.customerPhone.matches('^\\\\d{10,15}$')\n        && data.notes is string\n        && data.notes.size() <= 500\n        && data.status == 'pending'\n        && data.createdAt is timestamp\n        && data.updatedAt is timestamp;\n    }\n\n    match /tenants/{tenantId} {\n      allow get, list: if resource.data.active == true;\n      allow create, update, delete: if false;\n    }\n\n    match /services/{serviceId} {\n      allow get, list: if resource.data.active == true && tenantIsActive(resource.data.tenantId);\n      allow create, update, delete: if false;\n    }\n\n    match /businessHours/{businessHoursId} {\n      allow get, list: if resource.data.active == true && tenantIsActive(resource.data.tenantId);\n      allow create, update, delete: if false;\n    }\n\n    match /publicAppointments/{appointmentId} {\n      allow get, list: if tenantIsActive(resource.data.tenantId);\n\n      allow create: if isValidPublicAppointment(request.resource.data)\n        && existsAfter(/databases/$(database)/documents/appointments/$(appointmentId))\n        && getAfter(/databases/$(database)/documents/appointments/$(appointmentId)).data.tenantId == request.resource.data.tenantId\n        && getAfter(/databases/$(database)/documents/appointments/$(appointmentId)).data.date == request.resource.data.date\n        && getAfter(/databases/$(database)/documents/appointments/$(appointmentId)).data.time == request.resource.data.time\n        && getAfter(/databases/$(database)/documents/appointments/$(appointmentId)).data.status == request.resource.data.status;\n\n      allow update, delete: if false;\n    }\n\n    match /appointments/{appointmentId} {\n      allow get, list, update, delete: if false;\n\n      allow create: if isValidAppointment(request.resource.data)\n        && existsAfter(/databases/$(database)/documents/publicAppointments/$(appointmentId))\n        && getAfter(/databases/$(database)/documents/publicAppointments/$(appointmentId)).data.tenantId == request.resource.data.tenantId\n        && getAfter(/databases/$(database)/documents/publicAppointments/$(appointmentId)).data.date == request.resource.data.date\n        && getAfter(/databases/$(database)/documents/publicAppointments/$(appointmentId)).data.time == request.resource.data.time\n        && getAfter(/databases/$(database)/documents/publicAppointments/$(appointmentId)).data.status == request.resource.data.status;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-23T17:07:28.962783Z","metadata":{"services":["cloud.firestore"]}}
